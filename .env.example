# Copy this file to .env and fill in your values. .env is gitignored.
# (Use "copy .env.example .env" — copy, not move/rename.)

# --- GigaChat (LLM that figures out "what each person does") ---------------
# Get credentials in the Sber GigaChat personal cabinet:
#   https://developers.sber.ru/portal/products/gigachat-api
#
# Option A (recommended): put Client ID and Client Secret separately — the
# script base64-encodes "id:secret" into the Authorization key for you.
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
#
# Option B: if the cabinet gave you a ready-made base64 "Authorization key",
# put it here instead and leave the two fields above empty.
# GIGACHAT_AUTH_KEY=

# Scope: GIGACHAT_API_PERS (individuals) or GIGACHAT_API_CORP (business).
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Model: GigaChat | GigaChat-Pro | GigaChat-Max
GIGACHAT_MODEL=GigaChat-Pro

# TLS: GigaChat uses Russian Ministry-of-Digital-Development root certs. They are
# already bundled in certs/russian_trusted_ca.pem and loaded automatically, so
# normally you do NOT need to set anything here.
# Only if you want to point at your own CA bundle:
# GIGACHAT_CA_CERT=C:\path\to\russian_trusted_root_ca.cer
# Last resort (less safe) — skip certificate verification entirely:
# GIGACHAT_INSECURE_TLS=1

# --- WhatsApp Web version (only if the client hangs at "Loading 99%") ------
# Latest known-good version list: https://github.com/wppconnect-team/wa-version
# WWEB_REMOTE_PATH=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/<version>.html

# --- Scraper tuning (optional) --------------------------------------------
# SCRAPE_HEADLESS=0           # 1 = hide the Chrome window (CLI only)
# SCRAPE_MESSAGE_TARGET=3000  # how many group messages to load into memory
# SCRAPE_SCROLL_ROUNDS=25     # history-load rounds

# --- LLM tuning (optional) ------------------------------------------------
# LLM_CONCURRENCY=3
# LLM_MAX_CHARS=4000
